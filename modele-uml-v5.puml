@startuml
title GPS émotionnel V5 — questionnaire d’aide à l’identification

start
:Choisir parcours court ou complet;
:Afficher UNE question concrète;

if (Signe médical inquiétant ?) then (Oui)
  :Arrêter le questionnaire;
  :Orienter vers une aide médicale adaptée;
  stop
else (Non / difficile)
endif

partition "Observation" {
  repeat
    :Afficher une seule manifestation;
    if (Réponse ?) then (Oui)
      :Ajouter le poids de l’indice\naux hypothèses compatibles;
      :Conserver la question comme\nindice confirmé;
    elseif (Non)
      :Ne pas ajouter de preuve;
      note right
      Non ne signifie pas
      que l'émotion est absente.
      end note
    else (Difficile à dire)
      :Traiter comme donnée manquante;
      :Augmenter l’incertitude;
    endif
  repeat while (Questions restantes ?) is (Oui)
}

partition "Deux niveaux de preuve" {
  :Signes des fiches initiales\n= poids prioritaire;
  :Signes complémentaires de recherche\n= poids plus faible;
  :Questions de contexte\n= aide à la différenciation;
}

partition "Calcul" {
  :Pour chaque hypothèse,\ncalculer support / poids répondus;
  :Ne pas pénaliser les données manquantes;
  :Normaliser les compatibilités positives\npour obtenir un panorama à 100 %;
  :Calculer le taux de réponses claires;
}

partition "Restitution" {
  :Afficher 1 à 6 hypothèses;
  :Afficher les indices confirmés;
  :Afficher besoins possibles;
  :Rappeler les limites;
  if (Enregistrer ?) then (Oui)
    :Stockage local du panorama,\ndu contexte et des réponses;
  else (Non)
  endif
}
stop
@enduml